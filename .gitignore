# ===== Secrets & credentials =====
**/*.env
**/*.env.*
**/secrets
**/credentials
.config/git/credentials     # git credential store - never commit
**/*_rsa                    # SSH private keys
**/*_ed25519
**/*.pem
**/*.key

# ===== macOS noise =====
.DS_Store
**/.DS_Store
.Spotlight-V100
.Trashes

# ===== Neovim runtime artifacts =====
.config/nvim/plugin/         # packer/lazy compiled state - regenerates automatically
.config/nvim/lazy-lock.json  # optional: lock file for LazyVim (some prefer to commit this)
.config/nvim/.netrwhist
.config/nvim/swap/
.config/nvim/undo/
.config/nvim/backup/

# ===== Shell history =====
.config/zsh/.zsh_history
.config/zsh/.zsh_sessions/

# ===== tmux runtime =====
.config/tmux/resurrect/      # tmux-resurrect session saves (machine-specific)

# ===== Misc editor noise =====
*.swp
*.swo
*~

[core]
  excludesfile = ~/.gitignore_global